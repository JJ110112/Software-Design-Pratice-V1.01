rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── scores 集合：學生成績 ──
    // 前端完全禁止寫入，只能透過 Cloud Functions (admin SDK) 寫入
    match /scores/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── summaries 集合：排行榜結算摘要 ──
    match /summaries/{docId} {
      // 任何人可讀
      allow read: if true;
      // 只允許 Cloud Functions (admin SDK) 寫入，前端禁止
      allow write: if false;
    }

    // ── config 集合：班級名冊等設定 ──
    match /config/{docId} {
      // 任何人可讀（登入頁需要載入名冊）
      allow read: if true;
      // 寫入：必須已登入 + 文件大小上限 50KB
      allow write: if request.auth != null && request.resource.size() < 51200;
    }

    // ── 其他集合：預設全部拒絕 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
