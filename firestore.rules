rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ PROJECT OFFLINE (2026-06-17)
    // All read/write access disabled
    // Use archived 'offline' branch for reference if restoring

    // ── 全部集合：已停用 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
