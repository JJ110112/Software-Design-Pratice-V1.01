{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      "functions/**",
      "node_modules/**",
      "tests/**",
      ".claude/**",
      "test-results/**",
      "playwright.config.js",
      "package.json",
      "package-lock.json",
      ".gitignore",
      "CLAUDE.md",
      "*.md"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "emulators": {
    "firestore": {
      "port": 8080
    },
    "functions": {
      "port": 5001
    },
    "auth": {
      "port": 9099
    },
    "hosting": {
      "port": 5500
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
